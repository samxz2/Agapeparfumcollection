---
import Layout from '../layouts/Layout.astro';
import Carrito from '../components/vue/Carrito.vue';
import BestSellers from '../components/vue/BestSellers.vue';
import ProductoCard from '../components/vue/ProductoCard.vue';
import { perfumes } from '../data/perfumes.js';

// CAMBIA ESTE NÚMERO PARA MOSTRAR MÁS O MENOS PRODUCTOS INICIALES
const PRODUCTOS_INICIALES = 8;

const productosIniciales = perfumes.slice(0, PRODUCTOS_INICIALES);
const tieneMasPerfumes = perfumes.length > PRODUCTOS_INICIALES;
---

<Layout>
  <!-- Carrito flotante -->
  <div class="fixed bottom-4 right-4 z-50 md:top-20 md:bottom-auto">
    <Carrito client:load />
  </div>

  <!-- Hero Section -->
  <section class="bg-linear-to-r from-background via-surface to-background py-16 md:py-24">
    <div class="container mx-auto px-4 text-center">
      <img 
        src="https://i.ibb.co/CpHdX08t/1001879919.png" 
        alt="Agape Collection Parfum"
        class="h-20 md:h-28 mx-auto mb-6 animate-fade-in"
      />
      <h1 class="text-4xl md:text-6xl font-bold text-primary mb-4">
        Agape Collection Parfum
      </h1>
      <p class="text-lg md:text-xl text-text-muted max-w-2xl mx-auto mb-8">
        Descubre fragancias exclusivas que definen tu esencia.
      </p>
      
      <!-- Buscador -->
      <div class="max-w-md mx-auto mb-4">
        <input 
          type="text"
          id="searchInput"
          placeholder="🔍 Buscar perfumes por nombre, descripción o categoría..."
          class="w-full px-4 py-3 bg-surface border border-primary-dark/30 rounded-full text-text placeholder-text-muted focus:outline-none focus:border-primary transition-colors"
        />
      </div>
      
      <!-- Botón limpiar búsqueda -->
      <div class="text-center">
        <button 
          id="clearSearchBtn"
          class="px-4 py-2 bg-primary-dark/50 hover:bg-red-500/80 text-white rounded-full transition-all duration-300 text-sm hidden"
        >
          ✕ Limpiar búsqueda
        </button>
      </div>
    </div>
  </section>

  <!-- Filtros y Ordenamiento -->
  <div class="container mx-auto px-4 py-4 border-b border-primary-dark/30">
    <div class="flex flex-wrap gap-4 items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="text-text-muted text-sm">Estado:</span>
        <select id="estadoFilter" class="bg-surface border border-primary-dark/30 rounded-full px-4 py-2 text-text text-sm focus:outline-none focus:border-primary">
          <option value="todos">Todos</option>
          <option value="disponible">✅ Disponible</option>
          <option value="proximamente">⏳ Próximamente</option>
        </select>
      </div>
      
      <div class="flex items-center gap-2">
        <span class="text-text-muted text-sm">Ordenar por:</span>
        <select id="ordenFilter" class="bg-surface border border-primary-dark/30 rounded-full px-4 py-2 text-text text-sm focus:outline-none focus:border-primary">
          <option value="default">Predeterminado</option>
          <option value="nombre-asc">Nombre A - Z</option>
          <option value="nombre-desc">Nombre Z - A</option>
          <option value="precio-asc">Precio: menor a mayor</option>
          <option value="precio-desc">Precio: mayor a menor</option>
        </select>
      </div>
      
      <div class="text-text-muted text-sm">
        <span id="resultadosCount">{PRODUCTOS_INICIALES}</span> productos mostrados
      </div>
    </div>
  </div>

  <!-- Resultados de búsqueda -->
  <div id="searchResultsContainer" class="container mx-auto px-4 py-8" style="display: none;">
    <h2 id="searchResultsTitle" class="text-2xl font-bold text-primary mb-6"></h2>
    <div id="searchResultsGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"></div>
    <div class="text-center mt-8">
      <button id="backToStore" class="text-primary hover:underline transition">← Volver a la tienda</button>
    </div>
  </div>

  <!-- Contenido normal -->
  <div id="normalContent">
    <section class="container mx-auto px-4 py-16">
      <h2 class="text-3xl font-bold text-primary mb-8 text-center">Todos Nuestros Perfumes</h2>
      
      <div id="productosContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {productosIniciales.map(perfume => (
          <ProductoCard producto={perfume} client:load />
        ))}
      </div>

      <div id="verMasContainer" class="text-center mt-12">
        <button id="btnVerMas" class="px-6 py-3 bg-primary-dark hover:bg-primary text-white rounded-full transition-all duration-300 hover:scale-105">
          Ver más perfumes ({perfumes.length - PRODUCTOS_INICIALES} restantes)
        </button>
      </div>

      <div id="masProductosContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mt-8" style="display: none;">
        {perfumes.slice(PRODUCTOS_INICIALES).map(perfume => (
        <ProductoCard producto={perfume} client:visible />
        ))}
      </div>

      <p class="text-center text-text-muted text-sm mt-8">
        Mostrando <span id="normalCount">{PRODUCTOS_INICIALES}</span> de {perfumes.length} productos
      </p>
    </section>

    <!-- Categorías -->
    <section class="bg-surface/50 py-16">
      <div class="container mx-auto px-4">
        <h2 class="text-3xl font-bold text-primary mb-8 text-center">Categorías</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/caballero" class="bg-card p-6 rounded-2xl text-center hover:scale-105 transition-all duration-300 border border-primary-dark/30 hover:border-primary group">
            <div class="w-12 h-12 mx-auto mb-3 bg-primary/10 rounded-full flex items-center justify-center group-hover:bg-primary/20 transition">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <div class="font-semibold text-text">Caballero</div>
          </a>
          
          <a href="/dama" class="bg-card p-6 rounded-2xl text-center hover:scale-105 transition-all duration-300 border border-primary-dark/30 hover:border-primary group">
            <div class="w-12 h-12 mx-auto mb-3 bg-primary/10 rounded-full flex items-center justify-center group-hover:bg-primary/20 transition">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div class="font-semibold text-text">Dama</div>
          </a>
          
          <a href="/unisex" class="bg-card p-6 rounded-2xl text-center hover:scale-105 transition-all duration-300 border border-primary-dark/30 hover:border-primary group">
            <div class="w-12 h-12 mx-auto mb-3 bg-primary/10 rounded-full flex items-center justify-center group-hover:bg-primary/20 transition">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7zM12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div class="font-semibold text-text">Unisex</div>
          </a>
          
          <a href="/sets" class="bg-card p-6 rounded-2xl text-center hover:scale-105 transition-all duration-300 border border-primary-dark/30 hover:border-primary group">
            <div class="w-12 h-12 mx-auto mb-3 bg-primary/10 rounded-full flex items-center justify-center group-hover:bg-primary/20 transition">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div class="font-semibold text-text">Sets</div>
          </a>
        </div>
      </div>
    </section>

    <BestSellers client:load />
  </div>
</Layout>

<script>
// @ts-nocheck
if (typeof window !== 'undefined') {
  const PRODUCTOS_INICIALES = 8;
  
  let todosLosPerfumes = [];
  let ProductoCardComponent = null;
  let createApp = null;
  
  const normalContent = document.getElementById('normalContent');
  const searchResultsContainer = document.getElementById('searchResultsContainer');
  const searchResultsGrid = document.getElementById('searchResultsGrid');
  const searchResultsTitle = document.getElementById('searchResultsTitle');
  const backToStore = document.getElementById('backToStore');
  const searchInput = document.getElementById('searchInput');
  const clearSearchBtn = document.getElementById('clearSearchBtn');
  const estadoFilter = document.getElementById('estadoFilter');
  const ordenFilter = document.getElementById('ordenFilter');
  const resultadosCount = document.getElementById('resultadosCount');
  const normalCount = document.getElementById('normalCount');
  
  let modoBusqueda = false;
  
  const ordenarProductos = (productos, criterio) => {
    const productosCopy = [...productos];
    switch(criterio) {
      case 'nombre-asc':
        return productosCopy.sort((a, b) => a.nombre.localeCompare(b.nombre));
      case 'nombre-desc':
        return productosCopy.sort((a, b) => b.nombre.localeCompare(a.nombre));
      case 'precio-asc':
        return productosCopy.sort((a, b) => {
          const precioA = a.enOferta ? a.precioOferta : a.precio;
          const precioB = b.enOferta ? b.precioOferta : b.precio;
          return precioA - precioB;
        });
      case 'precio-desc':
        return productosCopy.sort((a, b) => {
          const precioA = a.enOferta ? a.precioOferta : a.precio;
          const precioB = b.enOferta ? b.precioOferta : b.precio;
          return precioB - precioA;
        });
      default:
        return productosCopy;
    }
  };
  
  const filtrarPorEstado = (productos, estado) => {
    if (estado === 'todos') return productos;
    return productos.filter(p => p.estadoEnvio === estado);
  };
  
  const mostrarResultadosBusqueda = async () => {
    const termino = searchInput.value.toLowerCase().trim();
    const estado = estadoFilter.value;
    const orden = ordenFilter.value;
    
    if (!termino) {
      modoBusqueda = false;
      normalContent.style.display = 'block';
      searchResultsContainer.style.display = 'none';
      actualizarProductosNormales();
      clearSearchBtn.classList.add('hidden');
      return;
    }
    
    let resultados = todosLosPerfumes.filter(p => 
      p.nombre.toLowerCase().includes(termino) ||
      p.descripcion.toLowerCase().includes(termino) ||
      p.categoria.toLowerCase().includes(termino)
    );
    
    resultados = filtrarPorEstado(resultados, estado);
    resultados = ordenarProductos(resultados, orden);
    
    if (!ProductoCardComponent || !createApp) {
      const cardModule = await import('../components/vue/ProductoCard.vue');
      const vueModule = await import('vue');
      ProductoCardComponent = cardModule.default;
      createApp = vueModule.createApp;
    }
    
    normalContent.style.display = 'none';
    searchResultsContainer.style.display = 'block';
    searchResultsTitle.textContent = `Resultados para "${termino}" (${resultados.length} productos)`;
    resultadosCount.textContent = resultados.length;
    clearSearchBtn.classList.remove('hidden');
    
    if (resultados.length === 0) {
      searchResultsGrid.innerHTML = '<div class="col-span-full text-center text-text-muted py-12">No se encontraron perfumes</div>';
      return;
    }
    
    searchResultsGrid.innerHTML = '';
    
    for (const producto of resultados) {
      const cardDiv = document.createElement('div');
      searchResultsGrid.appendChild(cardDiv);
      createApp(ProductoCardComponent, { producto }).mount(cardDiv);
    }
  };
  
  const actualizarProductosNormales = async () => {
    const estado = estadoFilter.value;
    const orden = ordenFilter.value;
    
    let productosFiltrados = filtrarPorEstado(todosLosPerfumes, estado);
    productosFiltrados = ordenarProductos(productosFiltrados, orden);
    
    resultadosCount.textContent = productosFiltrados.length;
    normalCount.textContent = productosFiltrados.length;
    
    const productosInicialesMostrar = productosFiltrados.slice(0, PRODUCTOS_INICIALES);
    const tieneMas = productosFiltrados.length > PRODUCTOS_INICIALES;
    
    if (!ProductoCardComponent || !createApp) {
      const cardModule = await import('../components/vue/ProductoCard.vue');
      const vueModule = await import('vue');
      ProductoCardComponent = cardModule.default;
      createApp = vueModule.createApp;
    }
    
    const productosContainer = document.getElementById('productosContainer');
    const masContainer = document.getElementById('masProductosContainer');
    const verMasContainerDiv = document.getElementById('verMasContainer');
    
    productosContainer.innerHTML = '';
    
    for (const producto of productosInicialesMostrar) {
      const cardDiv = document.createElement('div');
      productosContainer.appendChild(cardDiv);
      createApp(ProductoCardComponent, { producto }).mount(cardDiv);
    }
    
    if (tieneMas) {
      masContainer.innerHTML = '';
      const productosRestantes = productosFiltrados.slice(PRODUCTOS_INICIALES);
      for (const producto of productosRestantes) {
        const cardDiv = document.createElement('div');
        masContainer.appendChild(cardDiv);
        createApp(ProductoCardComponent, { producto }).mount(cardDiv);
      }
      masContainer.style.display = 'none';
      verMasContainerDiv.style.display = 'block';
      
      const btnVerMas = document.getElementById('btnVerMas');
      if (btnVerMas) {
        // Remover eventos anteriores y agregar nuevo
        const nuevoBtn = btnVerMas.cloneNode(true);
        btnVerMas.parentNode.replaceChild(nuevoBtn, btnVerMas);
        nuevoBtn.addEventListener('click', () => {
          masContainer.style.display = 'grid';
          nuevoBtn.parentNode.style.display = 'none';
        });
      }
    } else {
      verMasContainerDiv.style.display = 'none';
      masContainer.style.display = 'none';
    }
  };
  
  const cargarPerfumes = async () => {
    const module = await import('../data/perfumes.js');
    todosLosPerfumes = module.perfumes;
    actualizarProductosNormales();
  };
  
  cargarPerfumes();
  
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      modoBusqueda = e.target.value.trim().length > 0;
      mostrarResultadosBusqueda();
    });
  }
  
  if (clearSearchBtn) {
    clearSearchBtn.addEventListener('click', () => {
      searchInput.value = '';
      modoBusqueda = false;
      normalContent.style.display = 'block';
      searchResultsContainer.style.display = 'none';
      clearSearchBtn.classList.add('hidden');
      actualizarProductosNormales();
    });
  }
  
  if (estadoFilter) {
    estadoFilter.addEventListener('change', () => {
      if (modoBusqueda) {
        mostrarResultadosBusqueda();
      } else {
        actualizarProductosNormales();
      }
    });
  }
  
  if (ordenFilter) {
    ordenFilter.addEventListener('change', () => {
      if (modoBusqueda) {
        mostrarResultadosBusqueda();
      } else {
        actualizarProductosNormales();
      }
    });
  }
  
  if (backToStore) {
    backToStore.addEventListener('click', () => {
      searchInput.value = '';
      modoBusqueda = false;
      normalContent.style.display = 'block';
      searchResultsContainer.style.display = 'none';
      clearSearchBtn.classList.add('hidden');
      actualizarProductosNormales();
    });
  }
}
</script>