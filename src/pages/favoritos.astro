---
import Layout from '../layouts/Layout.astro';
import Carrito from '../components/vue/Carrito.vue';
---

<Layout>
  <div class="fixed bottom-20 right-4 z-50 md:top-20 md:bottom-auto">
    <Carrito client:load />
  </div>

  <section class="container mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <div class="flex justify-center mb-4">
        <svg class="w-16 h-16 text-red-500 fill-red-500" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4">Mis Favoritos</h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        Tus fragancias favoritas guardadas
      </p>
    </div>

    <div id="favoritos-container"></div>
  </section>
</Layout>

<script>
// @ts-nocheck
if (typeof window !== 'undefined') {
  let ProductoCardComponent = null;
  let createApp = null;
  let favoritosStore = null;
  
  const container = document.getElementById('favoritos-container');
  
  async function cargarFavoritos() {
    try {
      const [cardModule, vueModule, favoritosModule] = await Promise.all([
        import('../components/vue/ProductoCard.vue'),
        import('vue'),
        import('../store/favoritos.js')
      ]);
      
      ProductoCardComponent = cardModule.default;
      createApp = vueModule.createApp;
      favoritosStore = favoritosModule.useFavoritosStore();
      
      renderizarFavoritos();
    } catch (error) {
      console.error('Error:', error);
      if (container) {
        container.innerHTML = `<p class="text-red-500 text-center">Error: ${error.message}</p>`;
      }
    }
  }
  
  function renderizarFavoritos() {
    const favoritos = favoritosStore.items;
    
    if (!container) return;
    
    if (favoritos.length === 0) {
      container.innerHTML = `
        <div class="text-center py-20">
          <svg class="w-20 h-20 text-text-muted opacity-50 mx-auto mb-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
          </svg>
          <h2 class="text-2xl font-semibold text-text mb-2">No tienes favoritos aún</h2>
          <p class="text-text-muted mb-8">Guarda tus perfumes favoritos haciendo clic en el ❤️</p>
          <a href="/" class="inline-block px-6 py-3 bg-primary-dark hover:bg-primary text-white rounded-full transition-all">
            Explorar perfumes →
          </a>
        </div>
      `;
      return;
    }
    
    container.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="favoritos-grid"></div>
      <div class="text-center mt-8">
        <button id="vaciarFavoritosBtn" class="text-red-500 hover:text-red-400 transition text-sm">
          Vaciar favoritos
        </button>
      </div>
    `;
    
    const grid = document.getElementById('favoritos-grid');
    if (grid) {
      for (const producto of favoritos) {
        const cardDiv = document.createElement('div');
        grid.appendChild(cardDiv);
        const app = createApp(ProductoCardComponent, { producto });
        app.mount(cardDiv);
      }
    }
    
    const vaciarBtn = document.getElementById('vaciarFavoritosBtn');
    if (vaciarBtn) {
      vaciarBtn.addEventListener('click', () => {
        if (confirm('¿Seguro que quieres eliminar TODOS tus favoritos?')) {
          favoritosStore.vaciarFavoritos();
          renderizarFavoritos();
        }
      });
    }
  }
  
  window.addEventListener('storage', (e) => {
    if (e.key === 'favoritos-agape') {
      renderizarFavoritos();
    }
  });
  
  cargarFavoritos();
}
</script>