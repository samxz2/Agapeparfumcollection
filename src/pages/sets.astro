---
import Layout from '../layouts/Layout.astro';
import Carrito from '../components/vue/Carrito.vue';
import ProductoCard from '../components/vue/ProductoCard.vue';
import { perfumes } from '../data/perfumes.js';

const perfumesSets = perfumes.filter(p => p.categoria === 'sets');
---

<Layout>
<div class="fixed bottom-20 right-4 z-50 md:top-20 md:bottom-auto">
  <Carrito client:load />
</div>
  <section class="container mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4">Sets</h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        Colecciones especiales y regalos perfectos para cualquier ocasión
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {perfumesSets.map(perfume => (
        <ProductoCard producto={perfume} client:load />
      ))}
    </div>

    {perfumesSets.length === 0 && (
      <div class="text-center py-20">
        <p class="text-text-muted">Próximamente nuevos sets</p>
      </div>
    )}
  </section>
</Layout>